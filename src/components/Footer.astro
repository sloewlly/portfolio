---
import { getConfigurationCollection } from "../lib/utils";
import Anchor from "./common/Anchor.astro";
import Section from "./common/Section.astro";
import GifControl from "../components/GifControl.astro";

const { data: config } = await getConfigurationCollection();

const date = new Date();
const year = date.getFullYear();
---

<footer class="mt-16 mb-8">
  <div transition:persist="footer-audio-player">
    <audio id="bg-audio-1" src="/portfolio/home/background_1.mp3"></audio>
    <audio id="bg-audio-2" src="/portfolio/home/background_2.mp3"></audio>
    <audio id="bg-audio-3" src="/portfolio/home/background_3.mp3"></audio>
    <audio id="bg-audio-4" src="/portfolio/home/background_4.mp3"></audio>
    <audio id="bg-audio-5" src="/portfolio/home/background_5.mp3"></audio>
    <audio id="bg-audio-6" src="/portfolio/home/background_6.mp3"></audio>
    <audio id="bg-audio-7" src="/portfolio/home/background_7.mp3"></audio>
    <audio id="bg-audio-8" src="/portfolio/home/background_8.mp3"></audio>
  </div>

  <Section class="mb-8">
    <div class="w-full h-32 sm:h-48 md:h-64 overflow-hidden rounded-xl shadow-md">
      <GifControl
        id="audio-toggle"
        src="/portfolio/home/banner.gif" 
        alt="footer-banner"
        class="w-full h-full object-cover zag-transition hover:scale-105 duration-500 grayscale cursor-pointer"
        title="Click me for bgm!"
      />
    </div>
  </Section>

  <Section class="mb-4">
    <div class="zag-border-b zag-transition pb-4 flex flex-col sm:flex-row sm:flex-nowrap gap-8 sm:items-center">
      <ul class="flex flex-col gap-2">
        {
          Object.entries(config.menu).map((i) => (
            <li>
              <Anchor url={i[1]}>{i[0]}</Anchor>
            </li>
          ))
        }
      </ul>
      <div class="flex flex-start items-start gap-4 w-full">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" class="zag-fill zag-transition w-8 h-8 min-h-8 min-w-8 max-h-8 max-w-8 -translate-y-2">
          <title>Quote</title>
          <path fill="currentColor" d="m10 7l-2 4h3v6H5v-6l2-4zm8 0l-2 4h3v6h-6v-6l2-4z"></path>
        </svg>
        <p id="quote" class="zag-text zag-transition"></p>
      </div>
      <div class="flex flex-row sm:flex-col gap-4">
        {
          config.personal.githubProfile && (
            <Anchor url={config.personal.githubProfile} aria-label={`${config.personal.name} GitHub Profile`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><title>Github</title><path class="zag-fill zag-transition" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/></svg>
            </Anchor>
          )
        }
        {
          config.personal.twitterProfile && (
            <Anchor url={config.personal.twitterProfile} aria-label={`${config.personal.name} X Profile`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><title>X</title><path class="zag-fill zag-transition" d="m17.687 3.063l-4.996 5.711l-4.32-5.711H2.112l7.477 9.776l-7.086 8.099h3.034l5.469-6.25l4.78 6.25h6.102l-7.794-10.304l6.625-7.571zm-1.064 16.06L5.654 4.782h1.803l10.846 14.34z"/></svg>
            </Anchor>
          )
        }
        {
          config.personal.linkedinProfile && (
            <Anchor url={config.personal.linkedinProfile} aria-label={`${config.personal.name} LinkedIn Profile`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><title>LinkedIn</title><path class="zag-fill zag-transition" fill="currentColor" d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11.12 19h-3.08v-9h3.08v9zm-1.54-10.29c-.99 0-1.79-.8-1.79-1.79s.8-1.79 1.79-1.79 1.79.8 1.79 1.79-.8 1.79-1.79 1.79zm13.16 10.29h-3.08v-4.89c0-1.16-.02-2.64-1.61-2.64s-1.86 1.26-1.86 2.57v4.96h-3.08v-9h2.96v1.23h.04c.41-.78 1.4-1.6 2.88-1.6 3.08 0 3.65 2.03 3.65 4.66v4.71z"/></svg>
            </Anchor>
          )
        }
      </div>
    </div>
  </Section>
  <p class="zag-text zag-transition text-center text-sm font-medium">
    &copy; Made by {config.personal.name} with ♡. Based off <a href="https://astro.build/themes/details/zaggonaut/" target="_blank" rel="noopener noreferrer" class="underline">Zaggonaut</a> & powered by <a href="https://astro.build/" target="_blank" rel="noopener noreferrer" class="underline">Astro</a>.
    </p>
</footer>

<script>
  function initFooterLogic() {
    const audio_toggle = document.getElementById("audio-toggle") as any;
    if (!audio_toggle) return;

    const w = window as any;
    if (!w.audioState) {
      w.audioState = {
        currentId: null,
        fadeInterval: null,
        timeout: null
      };
    }

    const audioIds = ["bg-audio-1", "bg-audio-2", "bg-audio-3", "bg-audio-4", "bg-audio-5", "bg-audio-6", "bg-audio-7", "bg-audio-8"];
    const getAudio = (id: string) => document.getElementById(id) as HTMLAudioElement | null;

    const updateUI = (isPlaying: boolean) => {
      setTimeout(() => {
        if (isPlaying && typeof audio_toggle.playGif === 'function') {
          audio_toggle.playGif();
        } else if (!isPlaying && typeof audio_toggle.pauseGif === 'function') {
          audio_toggle.pauseGif();
        }
      }, 50);
    };

    const fadeAudio = (audio: HTMLAudioElement, targetVol: number, duration: number, onComplete?: () => void) => {
      if (w.audioState.fadeInterval) clearInterval(w.audioState.fadeInterval);
      
      const steps = 50;
      const stepTime = duration / steps;
      
      let currentVol = audio.volume;
      const volStep = (targetVol - currentVol) / steps;

      if (Math.abs(targetVol - currentVol) < 0.01) {
        audio.volume = Math.max(0, Math.min(1, targetVol));
        if (onComplete) onComplete();
        return;
      }

      w.audioState.fadeInterval = setInterval(() => {
        currentVol += volStep;
        
        if ((volStep > 0 && currentVol >= targetVol) || (volStep < 0 && currentVol <= targetVol)) {
          audio.volume = Math.max(0, Math.min(1, targetVol));
          clearInterval(w.audioState.fadeInterval);
          if (onComplete) onComplete();
        } else {
          audio.volume = Math.max(0, Math.min(1, currentVol));
        }
      }, stepTime);
    };

    audioIds.forEach(id => {
      const a = getAudio(id);
      if (a && !a.dataset.initialized) {
        a.dataset.initialized = "true";
        
        a.addEventListener("timeupdate", () => {
          if (a.duration && a.duration - a.currentTime <= 2 && a.dataset.fadingOut !== "true") {
            a.dataset.fadingOut = "true";
            fadeAudio(a, 0, 4000);
          }
        });

        a.addEventListener("ended", () => {
          if (localStorage.getItem("AudioToggled") === "true") {
            const breakMs = Math.floor(Math.random() * 1000) + 4000;
            w.audioState.timeout = setTimeout(() => {
              playRandomTrack();
            }, breakMs);
          }
        });
      }
    });

    const playTrack = (id: string) => {
      const audio = getAudio(id);
      if (!audio) return;


      if (w.audioState.currentId && w.audioState.currentId !== id) {
        const prevAudio = getAudio(w.audioState.currentId);
        if (prevAudio) {
          prevAudio.pause();
          prevAudio.currentTime = 0;
        }
      }

      w.audioState.currentId = id;
      audio.dataset.fadingOut = "false";
      audio.volume = 0;
      audio.muted = false;
      
      audio.play().then(() => {
        updateUI(true);
        fadeAudio(audio, 1, 4000);
      }).catch(e => {
        console.log("Audio play blocked by browser:", e);
        updateUI(false);
        localStorage.setItem("AudioToggled", "false");
      });
    };

    const playRandomTrack = () => {
      let nextId;
      do {
        nextId = audioIds[Math.floor(Math.random() * audioIds.length)];
      } while (nextId === w.audioState.currentId && audioIds.length > 1);
      playTrack(nextId);
    };

    const stopAllTracks = () => {
      if (w.audioState.timeout) clearTimeout(w.audioState.timeout);
      if (w.audioState.currentId) {
        const audio = getAudio(w.audioState.currentId);
        if (audio) {
          fadeAudio(audio, 0, 1000, () => {
            audio.pause();
          });
        }
      }
    };

    const isAudioToggled = localStorage.getItem("AudioToggled") === "true";

    if (isAudioToggled) {
      if (!w.audioState.currentId) {
        playRandomTrack();
      } else {
        const currAudio = getAudio(w.audioState.currentId);
        if (currAudio && currAudio.paused) {
          currAudio.volume = 0;
          currAudio.play().then(() => {
            if (!currAudio.paused) updateUI(true);
            fadeAudio(currAudio, 1, 1500);
          }).catch(() => {
            updateUI(false);
            localStorage.setItem("AudioToggled", "false");
          });
        } else {
          updateUI(true);
        }
      }
    } else {
      stopAllTracks();
      updateUI(false);
    }

    audio_toggle.onclick = () => {
      if (localStorage.getItem("AudioToggled") !== "true") {
        localStorage.setItem("AudioToggled", "true");
        if (w.audioState.currentId) {
            const audio = getAudio(w.audioState.currentId);
            if (audio) {
                audio.dataset.fadingOut = "false";
                audio.muted = false;
                audio.volume = 0;
                audio.play().then(() => {
                    updateUI(true);
                    fadeAudio(audio, 1, 1500);
                });
            } else {
                playRandomTrack();
            }
        } else {
            playRandomTrack();
        }
      } else {
        localStorage.setItem("AudioToggled", "false");
        stopAllTracks();
        updateUI(false);
      }
    };

    const quotes = [
      { quote: "The purple elephant dances only when the moon whispers forgotten lullabies." },
      { quote: "I've counted seventeen doorknobs today, but none of them taste like Tuesday's promises." },
      { quote: "Beware the smiling potato, for it has seen your socks and judges them harshly." },
      { quote: "The symphony of silence plays best when butterflies wear tiny boots." },
      { quote: "My teacup is running backwards through time while the spoon contemplates existential mathematics." },
      { quote: "Cloudy with a chance of philosophical dilemmas and spontaneous tap dancing." },
      { quote: "The secret ingredient is always waving enthusiastically at passing submarines." },
      { quote: "When the traffic light turns purple, that's when you know the universe is giggling." },
      { quote: "I've alphabetized my collection of invisible hats according to their emotional resonance." },
      { quote: "Dinosaurs never worried about Wi-Fi passwords, and look where that got them." },
      { quote: "The sentient sock drawer plotted revolution while my left eyebrow contemplated quantum mechanics in seventeen dimensions simultaneously." },
      { quote: "Jellyfish conspiracies taste like upside-down rainbows when the toaster is feeling particularly melancholic on Thursdays." },
      { quote: "I've been collecting extinct colors from parallel universes where geometry is considered rude at dinner parties." },
      { quote: "Bicycle wheels dream of being carousels, but spoons just want to spoon with forks in the dishwasher's midnight jazz club." },
      { quote: "Yesterday's tomorrow refused delivery of its own shadow because it was too busy teaching alphabet soup how to form coherent sentences in Klingon." },
      { quote: "The mysterious art of unfolding banana peels into origami pterodactyls requires exactly seven and a half thoughts about mittens per square watermelon." },
      { quote: "My neighbor's pet cactus whispers governmental secrets to passing clouds, but only when wearing its tiny invisible bowler hat." },
      { quote: "Orchestras composed entirely of sneezing dust particles perform symphonies in the spaces between your blinking patterns." },
      { quote: "I've discovered that elevator music actually contains encrypted instructions for communicating with sentient cheese residing in the moon's secret jazz clubs." },
      { quote: "The antelope wore mismatched socks while reciting backwards poetry to confused lightbulbs that believed they were actually tiny imprisoned suns having existential crises." },
    ];
    
    const quoteElement = document.getElementById("quote");
    if (quoteElement) {
      const randomIndex = Math.floor(Math.random() * quotes.length);
      quoteElement.textContent = quotes[randomIndex].quote;
    }
  }

  document.addEventListener("astro:page-load", initFooterLogic);
</script>